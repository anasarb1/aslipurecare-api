# AslipureCare API - Environment Variables
# Copy this file to .env and fill in your values
# Never commit .env to version control

# -------------------------------------------------------------------
# JWT Authentication
# -------------------------------------------------------------------

# Secret key used to sign JWT tokens - change this to a long random string in production
JWT_SECRET_KEY=your-super-secret-key-change-this

# Admin credentials for POST /auth/token
ADMIN_USER=admin
ADMIN_PASS=your-secure-password-here

# -------------------------------------------------------------------
# Database
# -------------------------------------------------------------------

# SQLAlchemy connection string
# SQLite (default, good for development):
DATABASE_URL=sqlite:///products.db

# PostgreSQL (recommended for production):
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# -------------------------------------------------------------------
# Server (optional)
# -------------------------------------------------------------------

# Port to listen on (Render sets this automatically)
PORT=5000
